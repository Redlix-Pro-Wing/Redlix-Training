// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  fullName        String
  password        String
  selectedRole    String
  otherRoleText   String?
  goals           String[]
  profileImage    String?
  collegeStudying String?  @default("")
  branch          String?  @default("")
  year            String?  @default("")
  dob             String?  @default("")
  portfolioLink   String?  @default("")
  linkedinLink    String?  @default("")
  about               String?  @default("")
  shareWithNetworking Boolean  @default(false)
  isPremium           Boolean  @default(false)
  otpCode             String?
  otpExpiry           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  content   String
  userId    String
  fullName  String
  email     String
  role        String
  recipientId String?
  reactions   Json?    @default("{}")
  seenBy      Json?    @default("{}")
  createdAt   DateTime @default(now())
}

model StudyPod {
  id          String   @id @default(uuid())
  name        String
  creatorId   String
  creatorName String
  createdAt       DateTime @default(now())
  approvedUserIds Json?    @default("[]")
  waitingUserIds  Json?    @default("[]")
}

model StudyPodMessage {
  id          String   @id @default(uuid())
  studyPodId String
  content     String
  userId      String
  fullName    String
  email       String
  createdAt   DateTime @default(now())
}

model StudyPodTodo {
  id          String   @id @default(uuid())
  studyPodId String
  title       String
  completed   Boolean  @default(false)
  creatorName String
  createdAt   DateTime @default(now())
}

model StudyPodIdea {
  id          String   @id @default(uuid())
  studyPodId String
  title       String
  description String
  creatorName String
  createdAt   DateTime @default(now())
}

model PaymentRequest {
  id          String   @id @default(uuid())
  userId      String
  userName    String
  userEmail   String
  plan        String
  referenceNo String
  name        String
  utrNo       String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

